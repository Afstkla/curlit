{
  "name": "curlit",
  "version": "0.2.2",
  "description": "A no-frills REST client that syncs through a private GitHub repo.",
  "author": "Afstkla",
  "main": "src/main/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "dist": "electron-builder --mac --publish never",
    "release": "electron-builder --mac --publish always"
  },
  "dependencies": {
    "isomorphic-git": "^1.27.1",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^27.0.1"
  },
  "build": {
    "appId": "io.neople.curlit",
    "productName": "Curlit",
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      "config.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "Afstkla",
      "repo": "curlit"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    }
  }
}
